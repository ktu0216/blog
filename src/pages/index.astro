---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { legacyPosts } from "../data/legacy.ts";

// 프로덕션 빌드에선 draft 제외(비공개 초안). dev에선 모두 보임.
const md = await getCollection("posts", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true,
);
const mdItems = md.map((p) => ({
  title: p.data.title,
  href: `/posts/${p.id}/`,
  date: p.data.date.toISOString().slice(0, 10),
  description: p.data.description,
  tags: p.data.tags,
  draft: p.data.draft,
  legacy: false,
}));
const legacyItems = legacyPosts.map((p) => ({
  title: p.title,
  href: `/legacy/${p.file}`,
  date: p.date,
  description: undefined as string | undefined,
  tags: [] as string[],
  draft: false,
  legacy: true,
}));
const posts = [...mdItems, ...legacyItems].sort((a, b) =>
  b.date.localeCompare(a.date),
);
---

<Base title="홈" description="Saegida — 시스템 구축·개발 기록 기술 블로그">
  <p class="lead">시스템을 만들며 배운 것들을 기록합니다.</p>
  <ul class="posts">
    {
      posts.map((p) => (
        <li>
          <a class="card" href={p.href}>
            <h2 class="t">
              {p.title}
              {p.draft && <span class="draft">draft</span>}
            </h2>
            {p.description && <p class="d">{p.description}</p>}
            <div class="meta">
              <span>{p.date}</span>
              {p.legacy && <span class="badge">이전 글</span>}
              {p.tags.slice(0, 3).map((t) => (
                <span class="badge">#{t}</span>
              ))}
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Base>

<style>
  .lead { color: var(--muted); margin: 0 0 2rem; }
  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .card {
    display: block;
    padding: 1.3rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      transform 0.15s ease;
  }
  .card:hover {
    text-decoration: none;
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(20, 30, 60, 0.08);
    transform: translateY(-2px);
  }
  .card .t {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.01em;
    line-height: 1.4;
    margin: 0 0 0.4rem;
  }
  .card .d {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 0.7rem;
  }
  .card .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.78rem;
    color: var(--muted);
  }
  .card .badge {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }
  .card .draft {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    margin-left: 0.5rem;
    vertical-align: middle;
  }
</style>
