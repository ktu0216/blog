---
interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const site = "Saegida";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {site}</title>
    {description && <meta name="description" content={description} />}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css"
    />
    <style is:global>
      :root {
        --bg: #0d1117;
        --panel: #161b22;
        --fg: #e6edf3;
        --muted: #8b949e;
        --accent: #6ee7b7;
        --border: #30363d;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        line-height: 1.7;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      header.site { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 2rem; }
      header.site .brand { font-size: 1.1rem; color: var(--accent); }
      header.site .tag { font-size: 0.8rem; color: var(--muted); }
      .muted { color: var(--muted); }
      hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
      pre, code { font-family: ui-monospace, monospace; }
      pre {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
      }
      code { background: var(--panel); padding: 0.1rem 0.3rem; border-radius: 4px; }
      pre code { background: none; padding: 0; }

      /* 마크다운 글 본문: 읽기 좋은 아티클 타이포(코드는 모노 유지) */
      article {
        font-family: "Pretendard", -apple-system, "Apple SD Gothic Neo",
          "Noto Sans KR", sans-serif;
        font-size: 1.0625rem;
        line-height: 1.8;
      }
      article > :first-child { margin-top: 0; }
      article img {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 1.75rem auto;
        border: 1px solid var(--border);
        border-radius: 10px;
      }
      article h2 {
        font-size: 1.5rem;
        line-height: 1.3;
        margin: 2.75rem 0 0.85rem;
        padding-top: 0.5rem;
      }
      article h3 { font-size: 1.2rem; margin: 2rem 0 0.6rem; }
      article p { margin: 1.05rem 0; }
      article ul, article ol { margin: 1.05rem 0; padding-left: 1.5rem; }
      article li { margin: 0.35rem 0; }
      article blockquote {
        margin: 1.6rem 0;
        padding: 0.6rem 1.1rem;
        border-left: 3px solid var(--accent);
        background: var(--panel);
        border-radius: 0 8px 8px 0;
        color: var(--fg);
      }
      article blockquote p { margin: 0.4rem 0; }
      article table { border-collapse: collapse; width: 100%; margin: 1.6rem 0; }
      article th, article td {
        border: 1px solid var(--border);
        padding: 0.55rem 0.8rem;
        text-align: left;
      }
      article th { background: var(--panel); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <a href="/" class="brand">{site}</a>
        <span class="tag">기술 블로그</span>
      </header>
      <slot />
    </div>
  </body>
</html>
